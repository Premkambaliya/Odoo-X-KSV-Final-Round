// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum Gender {
  Male
  Female
  Other
}

enum AccountStatus {
  Active
  Inactive
  Blocked
}

enum VehicleType {
  Two_Wheeler
  Four_Wheeler
}

enum VehicleStatus {
  Available
  Reserved
  Rented
  Maintenance
}

enum FuelType {
  Petrol
  Diesel
  Electric
  Hybrid
  CNG
}

enum TransmissionType {
  Manual
  Automatic
}

enum PickupType {
  Store_Pickup
  Home_Delivery
}

enum RentalUnit {
  Hour
  Day
  Week
  Month
}

enum ReturnCondition {
  Good
  Damaged
}

enum OrderStatus {
  Pending
  Confirmed
  Ready_for_Pickup
  Picked_Up
  Active
  Return_Pending
  Returned
  Inspection
  Refund_Pending
  Completed
  Cancelled
}

enum PaymentMethod {
  Cash
  Card
  UPI
  Net_Banking
}

enum PaymentStatus {
  Pending
  Paid
  Failed
  Refunded
}

enum RefundMethod {
  Cash
  UPI
  Bank_Transfer
}

enum RefundStatus {
  Pending
  Refunded
  Partially_Refunded
}

enum DepositStatus {
  Held
  Released
}

enum InvoiceStatus {
  Paid
  Pending
  Cancelled
}

model User {
  id                  String         @id @default(uuid()) @db.Uuid
  role                Role           @default(CUSTOMER)
  firstName           String         @map("first_name") @db.VarChar(100)
  lastName            String         @map("last_name") @db.VarChar(100)
  email               String         @unique @db.VarChar(255)
  phone               String?        @db.VarChar(20)
  password            String         @db.VarChar(255)
  profileImage        String?        @map("profile_image") @db.Text
  dateOfBirth         DateTime?      @map("date_of_birth") @db.Date
  gender              Gender?
  drivingLicenseNo    String?        @map("driving_license_no") @db.VarChar(100)
  drivingLicenseImage String?        @map("driving_license_image") @db.Text
  accountStatus       AccountStatus  @default(Active) @map("account_status")
  isVerified          Boolean        @default(false) @map("is_verified")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  addresses           UserAddresses[]
  rentalOrders        RentalOrder[]
  payments            Payment[]
  securityDeposits    SecurityDeposit[]
  invoices            Invoice[]

  @@map("users")
}

model UserAddresses {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  addressType String   @map("address_type") @db.VarChar(50)
  addressLine String   @map("address_line") @db.Text
  city        String   @db.VarChar(100)
  state       String   @db.VarChar(100)
  pincode     String   @db.VarChar(20)
  country     String   @db.VarChar(100)
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rentalOrders RentalOrder[]

  @@map("user_addresses")
}

model Category {
  id           String      @id @default(uuid()) @db.Uuid
  categoryName String      @unique @map("category_name") @db.VarChar(100)
  vehicleType  VehicleType @map("vehicle_type")
  description  String?     @db.Text
  status       Boolean     @default(true)
  createdAt    DateTime    @default(now()) @map("created_at")

  vehicles     Vehicle[]

  @@map("categories")
}

model Vehicle {
  id                 String         @id @default(uuid()) @db.Uuid
  categoryId         String         @map("category_id") @db.Uuid
  vehicleName        String         @map("vehicle_name") @db.VarChar(255)
  brand              String         @db.VarChar(100)
  model              String         @db.VarChar(100)
  year               Int
  registrationNumber String         @unique @map("registration_number") @db.VarChar(50)
  color              String         @db.VarChar(50)
  fuelType           FuelType       @map("fuel_type")
  transmission       TransmissionType
  seatCapacity       Int            @map("seat_capacity")
  mileage            Decimal        @db.Decimal(10, 2)
  engineCapacity     String?        @map("engine_capacity") @db.VarChar(100)
  currentOdometer    Int            @default(0) @map("current_odometer")
  rentPerHour        Decimal        @map("rent_per_hour") @db.Decimal(10, 2)
  rentPerDay         Decimal        @map("rent_per_day") @db.Decimal(10, 2)
  rentPerWeek        Decimal        @map("rent_per_week") @db.Decimal(10, 2)
  rentPerMonth       Decimal        @map("rent_per_month") @db.Decimal(10, 2)
  securityDeposit    Decimal        @map("security_deposit") @db.Decimal(10, 2)
  description        String?        @db.Text
  averageRating      Decimal        @default(0.0) @map("average_rating") @db.Decimal(3, 2)
  totalRentals       Int            @default(0) @map("total_rentals")
  lastServiceDate    DateTime?      @map("last_service_date") @db.Date
  status             VehicleStatus  @default(Available)
  createdAt          DateTime       @default(now()) @map("created_at")

  category           Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images             VehicleImage[]
  rentalOrders       RentalOrder[]

  @@map("vehicles")
}

model VehicleImage {
  id           String   @id @default(uuid()) @db.Uuid
  vehicleId    String   @map("vehicle_id") @db.Uuid
  imageUrl     String   @map("image_url") @db.Text
  isPrimary    Boolean  @default(false) @map("is_primary")
  displayOrder Int      @default(0) @map("display_order")

  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_images")
}

model RentalOrder {
  id                 String             @id @default(uuid()) @db.Uuid
  orderNumber        String             @unique @map("order_number") @db.VarChar(100)
  customerId         String             @map("customer_id") @db.Uuid
  vehicleId          String             @map("vehicle_id") @db.Uuid
  pickupType         PickupType         @map("pickup_type")
  deliveryAddressId  String?            @map("delivery_address_id") @db.Uuid
  pickupDate         DateTime           @map("pickup_date")
  pickupOtp          String?            @map("pickup_otp") @db.VarChar(20)
  pickupStatus       Boolean            @default(false) @map("pickup_status")
  expectedReturnDate DateTime           @map("expected_return_date")
  actualReturnDate   DateTime?          @map("actual_return_date")
  rentalUnit         RentalUnit         @map("rental_unit")
  rentalDuration     Int                @map("rental_duration")
  rentalAmount       Decimal            @map("rental_amount") @db.Decimal(10, 2)
  returnCondition    ReturnCondition?   @map("return_condition")
  returnRemarks      String?            @map("return_remarks") @db.Text
  orderStatus        OrderStatus        @default(Pending) @map("order_status")
  remarks            String?            @db.Text
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  customer           User               @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicle            Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  deliveryAddress    UserAddresses?     @relation(fields: [deliveryAddressId], references: [id], onDelete: SetNull)
  payment            Payment?
  securityDeposit    SecurityDeposit?
  invoice            Invoice?

  @@map("rental_orders")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  orderId       String        @unique @map("order_id") @db.Uuid
  customerId    String        @map("customer_id") @db.Uuid
  rentalAmount  Decimal       @map("rental_amount") @db.Decimal(10, 2)
  taxAmount     Decimal       @map("tax_amount") @db.Decimal(10, 2)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(10, 2)
  paymentMethod PaymentMethod @map("payment_method")
  transactionId String?       @unique @map("transaction_id") @db.VarChar(255)
  paymentStatus PaymentStatus @default(Pending) @map("payment_status")
  paymentDate   DateTime?     @map("payment_date")
  createdAt     DateTime      @default(now()) @map("created_at")

  order         RentalOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer      User          @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@map("payments")
}

model SecurityDeposit {
  id            String        @id @default(uuid()) @db.Uuid
  orderId       String        @unique @map("order_id") @db.Uuid
  customerId    String        @map("customer_id") @db.Uuid
  depositAmount Decimal       @map("deposit_amount") @db.Decimal(10, 2)
  penaltyAmount Decimal       @default(0) @map("penalty_amount") @db.Decimal(10, 2)
  penaltyReason String?       @map("penalty_reason") @db.Text
  refundAmount  Decimal       @default(0) @map("refund_amount") @db.Decimal(10, 2)
  refundMethod  RefundMethod? @map("refund_method")
  refundStatus  RefundStatus  @default(Pending) @map("refund_status")
  depositStatus DepositStatus @default(Held) @map("deposit_status")
  refundDate    DateTime?     @map("refund_date")
  remarks       String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")

  order         RentalOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer      User          @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@map("security_deposits")
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  invoiceNumber String        @unique @map("invoice_number") @db.VarChar(100)
  orderId       String        @unique @map("order_id") @db.Uuid
  customerId    String        @map("customer_id") @db.Uuid
  paymentId     String?       @map("payment_id") @db.Uuid
  issueDate     DateTime      @default(now()) @map("issue_date")
  rentalAmount  Decimal       @map("rental_amount") @db.Decimal(10, 2)
  taxAmount     Decimal       @map("tax_amount") @db.Decimal(10, 2)
  depositAmount Decimal       @map("deposit_amount") @db.Decimal(10, 2)
  penaltyAmount Decimal       @map("penalty_amount") @db.Decimal(10, 2)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(10, 2)
  invoiceStatus InvoiceStatus @default(Pending) @map("invoice_status")
  pdfUrl        String?       @map("pdf_url") @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")

  order         RentalOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer      User          @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@map("invoices")
}
